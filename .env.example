NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. If omitted, the app uses the first vendor row or creates a default one.
VIZORA_VENDOR_ID=

# Optional. Used for generated share links when deployed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional. Used by /api/products/[id]/ai-enrich to invoke the Supabase Edge Function.
# Defaults to NEXT_PUBLIC_SUPABASE_URL/functions/v1/product-image-ai when omitted.
SUPABASE_PRODUCT_AI_FUNCTION_URL=

# Supabase Edge Function secrets. Set these with `supabase secrets set ...`.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_SIZE=auto
